VITE_SUPABASE_URL=https://<your-project>.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_<fill-in>

# Origin of the consumer-facing site. Used as the Wompi post-payment redirect
# target and as the prefix for activity share deep-links.
VITE_PUBLIC_SITE_URL=https://minga-expeditions-mobile-web.vercel.app

# Optional. When true, the booking form requires a WhatsApp number and the
# post-payment webhook fires a WA utility message (~$0.008/msg in Colombia).
VITE_WHATSAPP_ENABLED=false
