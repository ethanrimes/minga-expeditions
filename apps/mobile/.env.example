EXPO_PUBLIC_SUPABASE_URL=https://<your-project>.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_<fill-in>

# Origin of the consumer-facing site. Used to build shareable deep links.
EXPO_PUBLIC_SITE_URL=https://minga-expeditions-web.vercel.app

# Optional. When true, the booking form requires a WhatsApp number and the
# post-payment webhook fires a WA utility message (~$0.008/msg in Colombia).
# Leave blank/false to collect email only.
EXPO_PUBLIC_WHATSAPP_ENABLED=false

# Sentry crash + error reporting. Leave blank to disable. Create a project
# at https://sentry.io/, then paste the React Native DSN here.
EXPO_PUBLIC_SENTRY_DSN=
