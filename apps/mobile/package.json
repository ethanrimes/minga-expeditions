{
  "name": "@minga/mobile",
  "version": "0.1.0",
  "private": true,
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "test": "jest"
  },
  "dependencies": {
    "@minga/i18n": "*",
    "@minga/logic": "*",
    "@minga/supabase": "*",
    "@minga/theme": "*",
    "@minga/types": "*",
    "@minga/ui": "*",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@sentry/react-native": "^8.11.1",
    "@supabase/supabase-js": "^2.105.4",
    "expo": "~54.0.34",
    "expo-file-system": "~19.0.22",
    "expo-image": "~3.0.11",
    "expo-image-picker": "~17.0.4",
    "expo-location": "~19.0.8",
    "expo-sensors": "~15.0.8",
    "expo-sharing": "~14.0.4",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-svg": "^15.12.1",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-webview": "^13.16.1"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@expo/ngrok": "^4.1.3",
    "@types/jest": "^29.5.12",
    "@types/react": "~19.1.0",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.0",
    "lucide-react-native": "^0.577.0",
    "typescript": "^6.0.3"
  },
  "jest": {
    "preset": "jest-expo",
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg|@minga/.*))"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/.expo/"
