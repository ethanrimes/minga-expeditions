# Required — Supabase project the admin reads/writes.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional — used by server-side admin actions that need to bypass RLS, e.g.
# promoting a user to admin. Keep this OUT of NEXT_PUBLIC_ and never expose
# it to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
