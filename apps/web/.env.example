VITE_SUPABASE_URL=https://<your-project>.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_<fill-in>

# Note on Wompi: the client never reads the public key from env. The
# wompi-create-order Edge Function returns it in the API response, so all
# three Wompi secrets (public, integrity, events) live in Supabase function
# env only — see supabase/functions/wompi-create-order/index.ts:46.

# Top-level WhatsApp gate. When 'true', the booking drawer asks for a phone
# number (required) and wompi-webhook fires a WhatsApp confirmation after
# approval. Anything else (unset, empty, "false") hides the field and skips
# the WA send. Must match the server-side WHATSAPP_ENABLED in Supabase
# function secrets to avoid the drawer asking for phone while the webhook
# silently drops it (or vice versa).
VITE_WHATSAPP_ENABLED=false
