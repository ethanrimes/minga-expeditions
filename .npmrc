# Match what we run locally so EAS / CI / fresh clones all install cleanly.
# Expo SDK 54 + React 19 + a few RN libs still on older peer ranges makes
# strict peer resolution reject the install; `legacy-peer-deps` is the same
# behavior npm 6 had and what every existing `npm install` in this repo
# uses. Remove this if every transitive dep ever lists compatible peers.
legacy-peer-deps=true
