# Dependencies
node_modules/
.pnp
.pnp.js

# Build output
dist/
build/
.next/
.expo/
.expo-shared/
web-build/
.vite/

# Env files (keep .example)
.env
.env.local
.env.*.local
!.env.example

# Supabase local
supabase/.branches
supabase/.temp
supabase/.env

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log

# IDE
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db

# Turbo
.turbo/

# Typescript
*.tsbuildinfo

# All PNG screenshots and ad-hoc images stay out of git.
# (Real app assets live under apps/*/assets and packages/*/assets — none
# of those are PNGs today; if that changes, add a negation like
# `!apps/mobile/assets/**/*.png` here.)
*.png

# Original brief from Giovanni (contains secret keys — never commit)
/app description.md
/pastes/
pastes

# Scratch / handover docs workspace. Tracked files in here stay tracked, but
# new docs (handover scratchpads, app config drops, etc.) aren't auto-added.
/docs/

# EAS build profile — contains baked Supabase env vars per environment.
# Each dev keeps their own copy; see apps/mobile/eas.example.json for the
# template and fill in from your Supabase dashboard.
apps/mobile/eas.json
play-store-description.md

# Native
ios/Pods/
android/.gradle/
android/build/
android/app/build/

# Locally downloaded dev tools (e.g. cloudflared.exe for tunnel script).
# Each dev fetches the right binary for their OS/arch; never commit.
/tools/
apps/mobile/tools/

# Playwright MCP debug output (console logs, snapshots) generated when
# Claude drives the browser to debug the web build. Pure ephemera.
.playwright-mcp/
.vercel
