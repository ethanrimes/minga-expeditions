# Supabase — shared across all apps.
# Copy to .env and to each app's env file (apps/web/.env.local, apps/mobile-web/.env.local, apps/mobile/.env).
# Fill in the values from your project at: https://app.supabase.com/project/<ref>/settings/api

# Public / publishable (safe in client bundles)
SUPABASE_URL=https://<your-project>.supabase.co
SUPABASE_ANON_KEY=sb_publishable_<fill-in>

# Vite-prefixed mirrors (for apps/web and apps/mobile-web)
VITE_SUPABASE_URL=https://<your-project>.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_<fill-in>

# Expo-prefixed mirrors (for apps/mobile)
EXPO_PUBLIC_SUPABASE_URL=https://<your-project>.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_<fill-in>

# Server-only — NEVER bundle this into a client app. Copy from the Supabase dashboard → Settings → API.
SUPABASE_SERVICE_ROLE_KEY=

# Session-pooler connection string (Settings → Database → Connection pooling).
# Replace <your-project> with the project ref, <YOUR-DB-PASSWORD> with the DB password.
SUPABASE_DB_URL=postgresql://postgres.<your-project>:<YOUR-DB-PASSWORD>@aws-1-us-west-2.pooler.supabase.com:5432/postgres

# ---------------------------------------------------------------------------
# Meta (Facebook / Instagram / WhatsApp). One app at developers.facebook.com
# covers all three products. App ID + Secret are pasted into the Supabase
# dashboard (Auth → Providers → Facebook). The App Secret is server-only —
# never bundle it into a client app. WhatsApp-specific keys live in the
# WHATSAPP_* section.
# ---------------------------------------------------------------------------
# Two Meta apps:
#   * App #1 (business) — WhatsApp Cloud API, Instagram, Pages (if added later)
#   * App #2 (auth)     — classic Facebook Login for Supabase consumer auth.
#                          Required separate because Facebook Login for
#                          Business doesn't expose email / public_profile
#                          scopes, which Supabase auth needs.
META_APP_ID=<fill-in>
META_APP_SECRET=<fill-in>
META_BUSINESS_ID=<fill-in>
META_AUTH_APP_ID=<fill-in>
META_AUTH_APP_SECRET=<fill-in>

# Google Cloud project + OAuth client for Google Sign-In via Supabase.
# Get GOOGLE_CLIENT_ID + GOOGLE_CLIENT_SECRET from console.cloud.google.com
# → APIs & Services → Credentials → Create OAuth 2.0 Client ID (Web).
GOOGLE_CLOUD_PROJECT_ID=<fill-in>
GOOGLE_CLOUD_PROJECT_NUMBER=<fill-in>
GOOGLE_CLIENT_ID=<fill-in>
GOOGLE_CLIENT_SECRET=<fill-in>

# WhatsApp Cloud API. WHATSAPP_TOKEN should be a permanent System User token
# in prod (the 24h temp token on the dashboard works for dev). PHONE_ID is
# numeric — what Graph API uses; BUSINESS_ACCOUNT_ID (WABA) gates template
# management. These are consumed by supabase/functions/whatsapp-send.
WHATSAPP_TOKEN=<fill-in>
WHATSAPP_PHONE_ID=<fill-in>
WHATSAPP_BUSINESS_ACCOUNT_ID=<fill-in>

# ---------------------------------------------------------------------------
# Wompi — payment processor (Colombia). Get these from the merchant dashboard
# at https://comercios.wompi.co/ → Desarrolladores → Llaves de API. While
# developing, stay in Sandbox mode; the values below should start with the
# `pub_test_`, `test_integrity_`, `test_events_` prefixes.
#
# These are consumed by the Supabase Edge Functions, NOT by client apps. Land
# them in Supabase via:  supabase secrets set --env-file .env
# ---------------------------------------------------------------------------
WOMPI_PUBLIC_KEY=pub_test_<fill-in>
WOMPI_INTEGRITY_KEY=test_integrity_<fill-in>
WOMPI_EVENTS_SECRET=test_events_<fill-in>

# ---------------------------------------------------------------------------
# Resend (transactional email). Get the API key from Vercel Marketplace →
# Resend or directly at https://resend.com/api-keys. Consumed by
# supabase/functions/email-send.
# ---------------------------------------------------------------------------
RESEND_API_KEY=<fill-in>
EMAIL_FROM=Minga Expeditions <onboarding@resend.dev>

# Where Wompi sends the user back after the widget closes. Use the public
# origin of apps/web — localhost in dev, real domain in prod.
PUBLIC_SITE_URL=http://localhost:5173
