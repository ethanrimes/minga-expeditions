# Supabase — shared across all apps.
# Copy to .env and to each app's env file (apps/web/.env.local, apps/mobile-web/.env.local, apps/mobile/.env)

# Public / publishable (safe in client bundles)
SUPABASE_URL=https://dgkmvoteliomghoctwrd.supabase.co
SUPABASE_ANON_KEY=sb_publishable_5vC9YnAxnOCyX_uIv4RbOw_ghS7ZScI

# Vite-prefixed mirrors (for apps/web and apps/mobile-web)
VITE_SUPABASE_URL=https://dgkmvoteliomghoctwrd.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_5vC9YnAxnOCyX_uIv4RbOw_ghS7ZScI

# Expo-prefixed mirrors (for apps/mobile)
EXPO_PUBLIC_SUPABASE_URL=https://dgkmvoteliomghoctwrd.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_5vC9YnAxnOCyX_uIv4RbOw_ghS7ZScI

# Server-only — NEVER bundle this into a client app. Copy from the Supabase dashboard → Settings → API.
