# Session-pooler connection string (Settings → Database → Connection pooling).
# Replace <YOUR-DB-PASSWORD> with the project's DB password before running migration scripts.
SUPABASE_DB_URL=postgresql://postgres.dgkmvoteliomghoctwrd:<YOUR-DB-PASSWORD>@aws-1-us-west-2.pooler.supabase.com:5432/postgres
